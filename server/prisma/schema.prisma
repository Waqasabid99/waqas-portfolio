generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  full_name           String
  email               String    @unique
  password            String
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  role   UserRole   @default(USER)
  status UserStatus @default(INACTIVE)

  projects      Project[]
  contactForms  ContactForm[]
  refreshTokens RefreshToken[]
  blogs         Blog[]

  @@map("users")
}

model RefreshToken {
  id        String @id @default(cuid())
  tokenHash String @unique
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  expiresAt DateTime
  revoked   Boolean  @default(false)

  ipHash    String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────
// CONTACT
// ─────────────────────────────────────────────

model ContactForm {
  id         String   @id @default(uuid())
  name       String
  email      String
  subject    String
  message    String
  user_id    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User? @relation(fields: [user_id], references: [id])

  @@map("contact_forms")
}

// ─────────────────────────────────────────────
// PORTFOLIO (admin showcase projects)
// ─────────────────────────────────────────────

model PortfolioProject {
  id           String   @id @default(uuid())
  title        String
  category     String
  image        String
  description  String
  technologies String // stored as JSON string
  live_url     String
  github_url   String?
  featured     Boolean  @default(false)
  status       String   @default("active")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("portfolio_projects")
}

// ─────────────────────────────────────────────
// CLIENT PROJECTS
// ─────────────────────────────────────────────

model Project {
  id            String   @id @default(uuid())
  username      String
  email         String
  password      String
  project_name  String
  project_title String
  category      String
  price         Float    @default(0)
  deadline      String?
  details       String?
  user_id       String
  status        String   @default("pending")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  statusHistory           ProjectStatusHistory[]
  webDevelopmentDetail    WebDevelopmentDetail?
  seoDetail               SeoDetail?
  digitalMarketingDetail  DigitalMarketingDetail?
  contentGenerationDetail ContentGenerationDetail?
  appDevelopmentDetail    AppDevelopmentDetail?

  @@map("projects")
}

model ProjectStatusHistory {
  id         String   @id @default(uuid())
  project_id String
  old_status String
  new_status String
  changed_by String
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_status_history")
}

// ─────────────────────────────────────────────
// WEB DEVELOPMENT
// ─────────────────────────────────────────────

model WebDevelopmentDetail {
  id         String   @id @default(uuid())
  project_id String   @unique
  tech       String   @default("")
  web_pages  Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project  Project                 @relation(fields: [project_id], references: [id], onDelete: Cascade)
  features WebDevelopmentFeature[]

  @@map("web_development_details")
}

model WebDevelopmentFeature {
  id                String   @id @default(uuid())
  web_dev_detail_id String
  feature           String
  price             Float    @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  webDevelopmentDetail WebDevelopmentDetail @relation(fields: [web_dev_detail_id], references: [id], onDelete: Cascade)

  @@map("web_development_features")
}

// ─────────────────────────────────────────────
// SEO
// ─────────────────────────────────────────────

model SeoDetail {
  id         String   @id @default(uuid())
  project_id String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project  Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  seoTypes SeoType[]

  @@map("seo_details")
}

model SeoType {
  id            String   @id @default(uuid())
  seo_detail_id String
  seo_type      String
  price         Float    @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  seoDetail SeoDetail @relation(fields: [seo_detail_id], references: [id], onDelete: Cascade)

  @@map("seo_types")
}

// ─────────────────────────────────────────────
// DIGITAL MARKETING
// ─────────────────────────────────────────────

model DigitalMarketingDetail {
  id               String   @id @default(uuid())
  project_id       String   @unique
  target_audience  String?
  marketing_budget Float?
  duration         String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  project         Project                   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  services        DigitalMarketingService[]
  socialPlatforms SocialPlatform[]

  @@map("digital_marketing_details")
}

model DigitalMarketingService {
  id                          String   @id @default(uuid())
  digital_marketing_detail_id String
  service                     String
  price                       Float    @default(0)
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt

  digitalMarketingDetail DigitalMarketingDetail @relation(fields: [digital_marketing_detail_id], references: [id], onDelete: Cascade)

  @@map("digital_marketing_services")
}

model SocialPlatform {
  id                          String   @id @default(uuid())
  digital_marketing_detail_id String
  platform                    String
  price                       Float    @default(0)
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt

  digitalMarketingDetail DigitalMarketingDetail @relation(fields: [digital_marketing_detail_id], references: [id], onDelete: Cascade)

  @@map("social_platforms")
}

// ─────────────────────────────────────────────
// CONTENT GENERATION
// ─────────────────────────────────────────────

model ContentGenerationDetail {
  id              String   @id @default(uuid())
  project_id      String   @unique
  volume          String?
  content_tone    String?
  target_keywords String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  project          Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  contentTypes     ContentType[]
  contentLanguages ContentLanguage[]

  @@map("content_generation_details")
}

model ContentType {
  id                           String   @id @default(uuid())
  content_generation_detail_id String
  content_type                 String
  price                        Float    @default(0)
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt

  contentGenerationDetail ContentGenerationDetail @relation(fields: [content_generation_detail_id], references: [id], onDelete: Cascade)

  @@map("content_types")
}

model ContentLanguage {
  id                           String   @id @default(uuid())
  content_generation_detail_id String
  language                     String
  price                        Float    @default(0)
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt

  contentGenerationDetail ContentGenerationDetail @relation(fields: [content_generation_detail_id], references: [id], onDelete: Cascade)

  @@map("content_languages")
}

// ─────────────────────────────────────────────
// APP DEVELOPMENT
// ─────────────────────────────────────────────

model AppDevelopmentDetail {
  id               String   @id @default(uuid())
  project_id       String   @unique
  app_type         String?
  complexity       String?
  target_platforms String?
  expected_users   Int?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  project     Project      @relation(fields: [project_id], references: [id], onDelete: Cascade)
  appFeatures AppFeature[]

  @@map("app_development_details")
}

model AppFeature {
  id                        String   @id @default(uuid())
  app_development_detail_id String
  feature                   String
  price                     Float    @default(0)
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  appDevelopmentDetail AppDevelopmentDetail @relation(fields: [app_development_detail_id], references: [id], onDelete: Cascade)

  @@map("app_features")
}

// ─────────────────────────────────────────────
// BLOG SYSTEM
// ─────────────────────────────────────────────

model Blog {
  id String @id @default(uuid())

  title String
  slug  String @unique

  excerpt      String
  content      Json
  cover_image  String?
  status       BlogStatus    @default(DRAFT)
  featured     Boolean       @default(false)
  views        Int           @default(0)
  reading_time Int?
  author_id    String?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  published_at DateTime?
  author       User?         @relation(fields: [author_id], references: [id])
  category_id  String?
  category     BlogCategory? @relation(fields: [category_id], references: [id])
  tags         BlogTag[]
  seo          BlogSEO?

  @@map("blogs")
}

model BlogCategory {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  blogs      Blog[]
  created_at DateTime @default(now())

  @@map("blog_categories")
}

model BlogTag {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  blogs Blog[]

  @@map("blog_tags")
}

model BlogSEO {
  id               String  @id @default(uuid())
  blog_id          String  @unique
  meta_title       String?
  meta_description String?
  keywords         String?
  og_image         String?
  blog             Blog    @relation(fields: [blog_id], references: [id], onDelete: Cascade)

  @@map("blog_seo")
}
